+static void
+pgwasm_free_fields(char **field_names, uint32_t *field_types, uint16_t field_count)
+{
+    if (field_names != NULL)
+    {
+        for (uint16_t i = 0; i < field_count; i++)
+            free(field_names[i]);
+    }
+    free(field_names);
+    free(field_types);
+}
