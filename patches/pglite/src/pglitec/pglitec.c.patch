+static char *
+pgwasm_output_to_json(void)
+{
+    char **field_names = NULL;
+    uint32_t *field_types = NULL;
+    uint16_t field_count = 0;
+    bool result_started = false;
+    bool rows_open = false;
+    bool first_row = true;
+    bool first_result = true;
+    int affected_rows_total = 0;
+    char *json = NULL;
+    size_t json_length = 0;
+    size_t json_capacity = 0;
+    size_t pos = 0;
+
+    if (!pgwasm_append(&json, &json_length, &json_capacity, "["))
+        goto oom;
+
+    while (pos + 5 <= pgwasm_output_length)
+    {
+        unsigned char tag = pgwasm_output_buffer[pos++];
+        uint32_t message_length = pgwasm_read_u32(pgwasm_output_buffer + pos);
+        const unsigned char *message = pgwasm_output_buffer + pos + 4;
+        size_t body_length;
+
+        pos += 4;
+        if (message_length < 4 || pos + message_length - 4 > pgwasm_output_length)
+            break;
+
+        body_length = message_length - 4;
+
+        if (tag == 'T')
+        {
+            size_t p = 2;
+            pgwasm_free_fields(field_names, field_types, field_count);
+            field_names = NULL;
+            field_types = NULL;
+            field_count = 0;
+
+            field_count = pgwasm_read_u16(message);
+            field_names = calloc(field_count, sizeof(char *));
+            field_types = calloc(field_count, sizeof(uint32_t));
+            if (field_names == NULL || field_types == NULL)
+                goto oom;
+
+            for (uint16_t i = 0; i < field_count; i++)
+            {
+                size_t name_start = p;
+                size_t name_length;
+
+                while (p < body_length && message[p] != '\0')
+                    p++;
+                if (p >= body_length)
+                    goto parse_error;
+
+                name_length = p - name_start;
+                field_names[i] = malloc(name_length + 1);
+                if (field_names[i] == NULL)
+                    goto oom;
+                memcpy(field_names[i], message + name_start, name_length);
+                field_names[i][name_length] = '\0';
+                p++;
+
+                if (p + 18 > body_length)
+                    goto parse_error;
+                field_types[i] = pgwasm_read_u32(message + p + 6);
+                p += 18;
+            }
+        }
+        else if (tag == 'D')
+        {
+            size_t p = 2;
+            uint16_t column_count = pgwasm_read_u16(message);
+
+            if (!result_started)
+            {
+                if (!first_result && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                    goto oom;
+                first_result = false;
+                if (!pgwasm_append(&json, &json_length, &json_capacity, "{\"rows\":["))
+                    goto oom;
+                result_started = true;
+                rows_open = true;
+                first_row = true;
+            }
+
+            if (!first_row && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                goto oom;
+            first_row = false;
+
+            if (!pgwasm_append(&json, &json_length, &json_capacity, "{"))
+                goto oom;
+
+            for (uint16_t i = 0; i < column_count; i++)
+            {
+                int32_t value_length;
+
+                if (p + 4 > body_length)
+                    goto parse_error;
+                value_length = (int32_t)pgwasm_read_u32(message + p);
+                p += 4;
+
+                if (i > 0 && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                    goto oom;
+
+                if (!pgwasm_append_json_string(&json, &json_length, &json_capacity,
+                                               field_names[i], strlen(field_names[i])) ||
+                    !pgwasm_append(&json, &json_length, &json_capacity, ":"))
+                    goto oom;
+
+                if (value_length < 0)
+                {
+                    if (!pgwasm_append(&json, &json_length, &json_capacity, "null"))
+                        goto oom;
+                }
+                else
+                {
+                    if (p + (size_t)value_length > body_length)
+                        goto parse_error;
+                    if (!pgwasm_append_json_string(&json, &json_length, &json_capacity,
+                                                   (const char *)message + p,
+                                                   (size_t)value_length))
+                        goto oom;
+                    p += (size_t)value_length;
+                }
+            }
+
+            if (!pgwasm_append(&json, &json_length, &json_capacity, "}"))
+                goto oom;
+        }
+        else if (tag == 'C')
+        {
+            int completion_rows = pgwasm_command_completion_rows((const char *) message);
+            int affected_rows;
+            char affected_buffer[64];
+
+            if (pgwasm_command_counts_affected_rows((const char *) message))
+                affected_rows_total += completion_rows;
+            affected_rows = affected_rows_total;
+
+            if (!result_started)
+            {
+                if (!first_result && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                    goto oom;
+                first_result = false;
+                if (!pgwasm_append(&json, &json_length, &json_capacity, "{\"rows\":["))
+                    goto oom;
+                result_started = true;
+                rows_open = true;
+            }
+
+            if (rows_open)
+            {
+                if (!pgwasm_append(&json, &json_length, &json_capacity, "],\"fields\":["))
+                    goto oom;
+                rows_open = false;
+            }
+
+            for (uint16_t i = 0; i < field_count; i++)
+            {
+                char type_buffer[64];
+                if (i > 0 && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                    goto oom;
+                snprintf(type_buffer, sizeof(type_buffer), ",\"dataTypeID\":%u}", field_types[i]);
+                if (!pgwasm_append(&json, &json_length, &json_capacity, "{\"name\":") ||
+                    !pgwasm_append_json_string(&json, &json_length, &json_capacity,
+                                               field_names[i], strlen(field_names[i])) ||
+                    !pgwasm_append(&json, &json_length, &json_capacity, type_buffer))
+                    goto oom;
+            }
+
+            snprintf(affected_buffer, sizeof(affected_buffer), "],\"affectedRows\":%d}", affected_rows);
+            if (!pgwasm_append(&json, &json_length, &json_capacity, affected_buffer))
+                goto oom;
+
+            result_started = false;
+            rows_open = false;
+            first_row = true;
+            pgwasm_free_fields(field_names, field_types, field_count);
+            field_names = NULL;
+            field_types = NULL;
+            field_count = 0;
+        }
+        else if (tag == 'E')
+        {
+            const char *severity = NULL;
+            const char *message_text = NULL;
+            const char *sqlstate = NULL;
+            size_t p = 0;
+
+            while (p < body_length && message[p] != '\0')
+            {
+                unsigned char field_type = message[p++];
+                const char *field_value = (const char *) message + p;
+                size_t field_length = strlen(field_value);
+
+                if (p + field_length >= body_length)
+                    break;
+
+                if (field_type == 'S')
+                    severity = field_value;
+                else if (field_type == 'M')
+                    message_text = field_value;
+                else if (field_type == 'C')
+                    sqlstate = field_value;
+
+                p += field_length + 1;
+            }
+
+            if (message_text != NULL && sqlstate != NULL && severity != NULL)
+                pgwasm_set_error("%s: %s (%s)", severity, message_text, sqlstate);
+            else if (message_text != NULL)
+                pgwasm_set_error("%s", message_text);
+            else
+                pgwasm_set_error("PostgreSQL returned an error");
+            goto parse_error;
+        }
+        else if (tag == 'A')
+        {
+            if (!pgwasm_append_notification_result(&json, &json_length,
+                                                   &json_capacity,
+                                                   &first_result, message,
+                                                   body_length))
+                goto parse_error;
+        }
+        else if (tag == 'N')
+        {
+            if (!pgwasm_append_notice_result(&json, &json_length,
+                                             &json_capacity,
+                                             &first_result, message,
+                                             body_length))
+                goto parse_error;
+        }
+
+        pos += body_length;
+    }
+
+    if (result_started)
+    {
+        if (rows_open && !pgwasm_append(&json, &json_length, &json_capacity, "],\"fields\":["))
+            goto oom;
+        for (uint16_t i = 0; i < field_count; i++)
+        {
+            char type_buffer[64];
+            if (i > 0 && !pgwasm_append(&json, &json_length, &json_capacity, ","))
+                goto oom;
+            snprintf(type_buffer, sizeof(type_buffer), ",\"dataTypeID\":%u}", field_types[i]);
+            if (!pgwasm_append(&json, &json_length, &json_capacity, "{\"name\":") ||
+                !pgwasm_append_json_string(&json, &json_length, &json_capacity,
+                                           field_names[i], strlen(field_names[i])) ||
+                !pgwasm_append(&json, &json_length, &json_capacity, type_buffer))
+                goto oom;
+        }
+        if (!pgwasm_append(&json, &json_length, &json_capacity, "],\"affectedRows\":0}"))
+            goto oom;
+    }
+
+    if (!pgwasm_append(&json, &json_length, &json_capacity, "]"))
+        goto oom;
+
+    pgwasm_free_fields(field_names, field_types, field_count);
+    return json;
+
+oom:
+    pgwasm_set_error("out of memory");
+parse_error:
+    pgwasm_free_fields(field_names, field_types, field_count);
+    free(json);
+    return NULL;
+}
