+static bool
+pgwasm_append(char **buffer, size_t *length, size_t *capacity, const char *text)
+{
+    size_t text_length = strlen(text);
+    if (*length + text_length + 1 > *capacity)
+    {
+        size_t new_capacity = *capacity == 0 ? 1024 : *capacity;
+        while (new_capacity < *length + text_length + 1)
+            new_capacity *= 2;
+
+        char *new_buffer = realloc(*buffer, new_capacity);
+        if (new_buffer == NULL)
+            return false;
+
+        *buffer = new_buffer;
+        *capacity = new_capacity;
+    }
+
+    memcpy(*buffer + *length, text, text_length);
+    *length += text_length;
+    (*buffer)[*length] = '\0';
+    return true;
+}
+
+static bool
+pgwasm_append_json_string(char **buffer, size_t *length, size_t *capacity,
+                          const char *text, size_t text_length)
+{
+    if (!pgwasm_append(buffer, length, capacity, "\""))
+        return false;
+
+    for (size_t i = 0; i < text_length; i++)
+    {
+        unsigned char c = (unsigned char)text[i];
+        char escaped[8];
+
+        if (c == '"' || c == '\\')
+        {
+            escaped[0] = '\\';
+            escaped[1] = (char)c;
+            escaped[2] = '\0';
+            if (!pgwasm_append(buffer, length, capacity, escaped))
+                return false;
+        }
+        else if (c == '\n')
+        {
+            if (!pgwasm_append(buffer, length, capacity, "\\n"))
+                return false;
+        }
+        else if (c == '\r')
+        {
+            if (!pgwasm_append(buffer, length, capacity, "\\r"))
+                return false;
+        }
+        else if (c == '\t')
+        {
+            if (!pgwasm_append(buffer, length, capacity, "\\t"))
+                return false;
+        }
+        else if (c < 0x20)
+        {
+            snprintf(escaped, sizeof(escaped), "\\u%04x", c);
+            if (!pgwasm_append(buffer, length, capacity, escaped))
+                return false;
+        }
+        else
+        {
+            escaped[0] = (char)c;
+            escaped[1] = '\0';
+            if (!pgwasm_append(buffer, length, capacity, escaped))
+                return false;
+        }
+    }
+
+    return pgwasm_append(buffer, length, capacity, "\"");
+}
