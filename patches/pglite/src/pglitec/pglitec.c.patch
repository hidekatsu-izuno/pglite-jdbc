+static bool
+pgwasm_command_counts_affected_rows(const char *completion_tag)
+{
+    return strncmp(completion_tag, "INSERT ", 7) == 0 ||
+           strncmp(completion_tag, "UPDATE ", 7) == 0 ||
+           strncmp(completion_tag, "DELETE ", 7) == 0 ||
+           strncmp(completion_tag, "MERGE ", 6) == 0 ||
+           strncmp(completion_tag, "COPY ", 5) == 0 ||
+           strncmp(completion_tag, "MOVE ", 5) == 0 ||
+           strncmp(completion_tag, "FETCH ", 6) == 0;
+}
+
+static int
+pgwasm_command_completion_rows(const char *completion_tag)
+{
+    const char *end = completion_tag + strlen(completion_tag);
+    const char *start;
+    long value = 0;
+
+    if (end == completion_tag || end[-1] < '0' || end[-1] > '9')
+        return 0;
+
+    while (end > completion_tag && end[-1] >= '0' && end[-1] <= '9')
+        end--;
+
+    start = end;
+    while (*end >= '0' && *end <= '9')
+    {
+        value = value * 10 + (*end - '0');
+        end++;
+    }
+    if (*end != '\0' || start == completion_tag)
+        return 0;
+    return (int)value;
+}
