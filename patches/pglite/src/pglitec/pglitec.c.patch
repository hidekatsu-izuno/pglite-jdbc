+static bool
+pgwasm_append_notification_result(char **json, size_t *json_length,
+                                 size_t *json_capacity, bool *first_result,
+                                 const unsigned char *message,
+                                 size_t body_length)
+{
+    size_t channel_start = 4;
+    size_t channel_length;
+    size_t payload_start;
+    size_t payload_length;
+
+    if (body_length < 6)
+        return false;
+
+    while (channel_start < body_length && message[channel_start] != '\0')
+        channel_start++;
+    if (channel_start >= body_length)
+        return false;
+    channel_length = channel_start - 4;
+    payload_start = channel_start + 1;
+
+    payload_length = payload_start;
+    while (payload_length < body_length && message[payload_length] != '\0')
+        payload_length++;
+    if (payload_length >= body_length)
+        return false;
+    payload_length -= payload_start;
+
+    if (!*first_result && !pgwasm_append(json, json_length, json_capacity, ","))
+        return false;
+    *first_result = false;
+
+    return pgwasm_append(json, json_length, json_capacity,
+                         "{\"rows\":[],\"fields\":[],\"affectedRows\":0,\"notifications\":[{\"channel\":") &&
+           pgwasm_append_json_string(json, json_length, json_capacity,
+                                     (const char *) message + 4,
+                                     channel_length) &&
+           pgwasm_append(json, json_length, json_capacity, ",\"payload\":") &&
+           pgwasm_append_json_string(json, json_length, json_capacity,
+                                     (const char *) message + payload_start,
+                                     payload_length) &&
+           pgwasm_append(json, json_length, json_capacity, "}]}");
+}
+
+static bool
+pgwasm_append_notice_result(char **json, size_t *json_length,
+                            size_t *json_capacity, bool *first_result,
+                            const unsigned char *message,
+                            size_t body_length)
+{
+    const char *severity = NULL;
+    const char *severity_nonlocalized = NULL;
+    const char *message_text = NULL;
+    const char *sqlstate = NULL;
+    const char *detail = NULL;
+    const char *hint = NULL;
+    const char *routine = NULL;
+    size_t p = 0;
+    bool first_field = true;
+
+    while (p < body_length && message[p] != '\0')
+    {
+        unsigned char field_type = message[p++];
+        const char *field_value = (const char *) message + p;
+        size_t field_length = strlen(field_value);
+
+        if (p + field_length >= body_length)
+            break;
+
+        if (field_type == 'S')
+            severity = field_value;
+        else if (field_type == 'V')
+            severity_nonlocalized = field_value;
+        else if (field_type == 'M')
+            message_text = field_value;
+        else if (field_type == 'C')
+            sqlstate = field_value;
+        else if (field_type == 'D')
+            detail = field_value;
+        else if (field_type == 'H')
+            hint = field_value;
+        else if (field_type == 'R')
+            routine = field_value;
+
+        p += field_length + 1;
+    }
+
+    if (!*first_result && !pgwasm_append(json, json_length, json_capacity, ","))
+        return false;
+    *first_result = false;
+
+    if (!pgwasm_append(json, json_length, json_capacity,
+                       "{\"rows\":[],\"fields\":[],\"affectedRows\":0,\"notices\":[{"))
+        return false;
+
+#define PGLITE_APPEND_NOTICE_FIELD(key, value) \
+    do { \
+        if ((value) != NULL) { \
+            if (!first_field && !pgwasm_append(json, json_length, json_capacity, ",")) \
+                return false; \
+            first_field = false; \
+            if (!pgwasm_append(json, json_length, json_capacity, "\"" key "\":") || \
+                !pgwasm_append_json_string(json, json_length, json_capacity, \
+                                          (value), strlen(value))) \
+                return false; \
+        } \
+    } while (0)
+
+    PGLITE_APPEND_NOTICE_FIELD("severity", severity);
+    PGLITE_APPEND_NOTICE_FIELD("severityNonlocalized", severity_nonlocalized);
+    PGLITE_APPEND_NOTICE_FIELD("message", message_text);
+    PGLITE_APPEND_NOTICE_FIELD("code", sqlstate);
+    PGLITE_APPEND_NOTICE_FIELD("detail", detail);
+    PGLITE_APPEND_NOTICE_FIELD("hint", hint);
+    PGLITE_APPEND_NOTICE_FIELD("routine", routine);
+#undef PGLITE_APPEND_NOTICE_FIELD
+
+    return pgwasm_append(json, json_length, json_capacity, "}]}");
+}
