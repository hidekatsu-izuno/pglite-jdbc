+int EMSCRIPTEN_KEEPALIVE pgl_rename(const char *from, const char *to) {
+	char buffer[8192];
+	size_t nread;
+	int saved_errno;
+	FILE *src;
+	FILE *dst;
+
+	if (rename(from, to) == 0)
+		return 0;
+
+	if (errno != ENOTSUP && errno != ENOSYS
+#ifdef EOPNOTSUPP
+		&& errno != EOPNOTSUPP
+#endif
+		)
+		return -1;
+
+	src = fopen(from, "rb");
+	if (src == NULL)
+		return -1;
+
+	(void) unlink(to);
+	dst = fopen(to, "wb");
+	if (dst == NULL)
+	{
+		saved_errno = errno;
+		fclose(src);
+		errno = saved_errno;
+		return -1;
+	}
+
+	while ((nread = fread(buffer, 1, sizeof(buffer), src)) > 0)
+	{
+		if (fwrite(buffer, 1, nread, dst) != nread)
+		{
+			saved_errno = errno;
+			fclose(src);
+			fclose(dst);
+			(void) unlink(to);
+			errno = saved_errno;
+			return -1;
+		}
+	}
+
+	if (ferror(src))
+	{
+		saved_errno = errno;
+		fclose(src);
+		fclose(dst);
+		(void) unlink(to);
+		errno = saved_errno;
+		return -1;
+	}
+
+	if (fclose(dst) != 0)
+	{
+		saved_errno = errno;
+		fclose(src);
+		(void) unlink(to);
+		errno = saved_errno;
+		return -1;
+	}
+
+	if (fclose(src) != 0)
+		return -1;
+
+	if (unlink(from) != 0)
+	{
+		saved_errno = errno;
+		(void) unlink(to);
+		errno = saved_errno;
+		return -1;
+	}
+
+	return 0;
+}
