+static char *
+pgwasm_exec_json_internal(const char *sql)
+{
+    size_t sql_length = strlen(sql);
+    uint32_t message_length = (uint32_t)(sql_length + 5);
+    size_t packet_length = sql_length + 6;
+
+    free(pgwasm_input_buffer);
+    pgwasm_input_buffer = malloc(packet_length);
+    if (pgwasm_input_buffer == NULL)
+    {
+        pgwasm_set_error("out of memory");
+        return NULL;
+    }
+
+    pgwasm_input_buffer[0] = 'Q';
+    pgwasm_input_buffer[1] = (message_length >> 24) & 0xff;
+    pgwasm_input_buffer[2] = (message_length >> 16) & 0xff;
+    pgwasm_input_buffer[3] = (message_length >> 8) & 0xff;
+    pgwasm_input_buffer[4] = message_length & 0xff;
+    memcpy(pgwasm_input_buffer + 5, sql, sql_length);
+    pgwasm_input_buffer[5 + sql_length] = '\0';
+
+    pgwasm_input_length = packet_length;
+    pgwasm_input_offset = 0;
+    pgwasm_output_length = 0;
+
+    pgwasm_query_active = true;
+    while (pgwasm_input_offset < pgwasm_input_length || pq_buffer_remaining_data() > 0)
+    {
+        if (setjmp(pgwasm_query_jmp) == 0)
+            PostgresMainLoopOnce();
+        else
+            PostgresMainLongJmp();
+    }
+    PostgresSendReadyForQueryIfNecessary();
+    pgl_pq_flush();
+    pgwasm_query_active = false;
+
+    return pgwasm_output_to_json();
+}
