+static ssize_t
+pgwasm_socket_read(void *buffer, size_t max_length)
+{
+    size_t remaining = pgwasm_input_length - pgwasm_input_offset;
+    size_t n = remaining < max_length ? remaining : max_length;
+
+    if (n > 0)
+    {
+        memcpy(buffer, pgwasm_input_buffer + pgwasm_input_offset, n);
+        pgwasm_input_offset += n;
+    }
+
+    return (ssize_t)n;
+}
+
+static ssize_t
+pgwasm_socket_write(const void *buffer, size_t length)
+{
+    if (pgwasm_output_length + length > pgwasm_output_capacity)
+    {
+        size_t new_capacity = pgwasm_output_capacity == 0 ? 4096 : pgwasm_output_capacity;
+        while (new_capacity < pgwasm_output_length + length)
+            new_capacity *= 2;
+
+        unsigned char *new_buffer = realloc(pgwasm_output_buffer, new_capacity);
+        if (new_buffer == NULL)
+            return -1;
+
+        pgwasm_output_buffer = new_buffer;
+        pgwasm_output_capacity = new_capacity;
+    }
+
+    memcpy(pgwasm_output_buffer + pgwasm_output_length, buffer, length);
+    pgwasm_output_length += length;
+    return (ssize_t)length;
+}
