+static uint16_t
+pgwasm_read_u16(const unsigned char *ptr)
+{
+    return ((uint16_t)ptr[0] << 8) | ptr[1];
+}
+
+static uint32_t
+pgwasm_read_u32(const unsigned char *ptr)
+{
+    return ((uint32_t)ptr[0] << 24) | ((uint32_t)ptr[1] << 16) |
+           ((uint32_t)ptr[2] << 8) | ptr[3];
+}
