+		/* Read the docid page */
+		docid_buf = ReadBuffer(index_rel, current_page);
+		LockBuffer(docid_buf, BUFFER_LOCK_SHARE);
+		docid_page	 = BufferGetPage(docid_buf);
+		docid_header = (TpDocidPageHeader *)PageGetContents(docid_page);
