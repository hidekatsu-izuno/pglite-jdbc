+static void
+tp_check_hard_limit(void)
+{
+	uint64 limit_bytes;
+	uint64 dsa_bytes;
+
+	if (tp_memory_limit <= 0)
+		return;
+
+	limit_bytes = tp_hard_limit_bytes();
+
+	tp_registry_update_dsa_counter();
+	dsa_bytes = tp_registry_get_total_dsa_bytes();
