+	if (dsa_bytes > limit_bytes)
+		ereport(ERROR,
+				(errcode(ERRCODE_PROGRAM_LIMIT_EXCEEDED),
+				 errmsg("pg_textsearch DSA memory "
+						"(" UINT64_FORMAT " kB) exceeds "
+						"memory_limit "
+						"(%d kB)",
+						(uint64)(dsa_bytes / 1024),
+						tp_memory_limit),
+				 errhint("Increase pg_textsearch."
+						 "memory_limit or spill "
+						 "indexes with "
