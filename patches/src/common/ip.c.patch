@@ -53,6 +57,77 @@ int
 pg_getaddrinfo_all(const char *hostname, const char *servname,
 				   const struct addrinfo *hintp, struct addrinfo **result)
 {
+#ifdef __wasi__
+	struct addrinfo *ai;
+	int			family = hintp ? hintp->ai_family : AF_UNSPEC;
+	int			socktype = hintp ? hintp->ai_socktype : 0;
+	int			protocol = hintp ? hintp->ai_protocol : 0;
+	int			port = 0;
+
+	*result = NULL;
+
+	if (hostname == NULL || hostname[0] == '\0')
+		return EAI_NONAME;
+
+	if (servname != NULL && servname[0] != '\0')
+		port = atoi(servname);
+
+	if (family == AF_UNSPEC || family == AF_INET)
+	{
+		struct sockaddr_in *addr = calloc(1, sizeof(*addr));
+
+		if (addr == NULL)
+			return EAI_MEMORY;
+		if (inet_pton(AF_INET, hostname, &addr->sin_addr) == 1)
+		{
+			ai = calloc(1, sizeof(*ai));
+			if (ai == NULL)
+			{
+				free(addr);
+				return EAI_MEMORY;
+			}
+			addr->sin_family = AF_INET;
+			addr->sin_port = htons(port);
+			ai->ai_family = AF_INET;
+			ai->ai_socktype = socktype;
+			ai->ai_protocol = protocol;
+			ai->ai_addrlen = sizeof(*addr);
+			ai->ai_addr = (struct sockaddr *) addr;
+			*result = ai;
+			return 0;
+		}
+		free(addr);
+	}
+
+	if (family == AF_UNSPEC || family == AF_INET6)
+	{
+		struct sockaddr_in6 *addr = calloc(1, sizeof(*addr));
+
+		if (addr == NULL)
+			return EAI_MEMORY;
+		if (inet_pton(AF_INET6, hostname, &addr->sin6_addr) == 1)
+		{
+			ai = calloc(1, sizeof(*ai));
+			if (ai == NULL)
+			{
+				free(addr);
+				return EAI_MEMORY;
+			}
+			addr->sin6_family = AF_INET6;
+			addr->sin6_port = htons(port);
+			ai->ai_family = AF_INET6;
+			ai->ai_socktype = socktype;
+			ai->ai_protocol = protocol;
+			ai->ai_addrlen = sizeof(*addr);
+			ai->ai_addr = (struct sockaddr *) addr;
+			*result = ai;
+			return 0;
+		}
+		free(addr);
+	}
+
+	return EAI_FAIL;
+#else
 	int			rc;
 
 	/* not all versions of getaddrinfo() zero *result on failure */
@@ -66,6 +141,7 @@ pg_getaddrinfo_all(const char *hostname, const char *servname,
 					 servname, hintp, result);
 
 	return rc;
+#endif
 }
 
 
