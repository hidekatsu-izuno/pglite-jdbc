diff --git a/src/include/netdb.h b/src/include/netdb.h
new file mode 100644
index 0000000000..d295a9e75f
--- /dev/null
+++ b/src/include/netdb.h
@@ -0,0 +1,58 @@
+#ifndef PGLITE_WASI_NETDB_H
+#define PGLITE_WASI_NETDB_H
+
+#include <sys/socket.h>
+
+#define AI_PASSIVE 0x0001
+#define AI_CANONNAME 0x0002
+#define AI_NUMERICHOST 0x0004
+#define AI_NUMERICSERV 0x0400
+
+#define EAI_FAIL -4
+#define EAI_MEMORY -10
+#define EAI_NONAME -2
+#define EAI_SERVICE -8
+
+#ifndef PGLITE_WASI_ADDRINFO_DEFINED
+#define PGLITE_WASI_ADDRINFO_DEFINED
+struct addrinfo
+{
+	int ai_flags;
+	int ai_family;
+	int ai_socktype;
+	int ai_protocol;
+	socklen_t ai_addrlen;
+	struct sockaddr *ai_addr;
+	char *ai_canonname;
+	struct addrinfo *ai_next;
+};
+#endif
+
+struct hostent
+{
+	char *h_name;
+	char **h_aliases;
+	int h_addrtype;
+	int h_length;
+	char **h_addr_list;
+};
+
+static inline int
+getaddrinfo(const char *node, const char *service,
+			const struct addrinfo *hints, struct addrinfo **res)
+{
+	(void) node;
+	(void) service;
+	(void) hints;
+	if (res)
+		*res = 0;
+	return EAI_FAIL;
+}
+
+static inline void
+freeaddrinfo(struct addrinfo *res)
+{
+	(void) res;
+}
+
+#endif
