diff --git a/src/include/pwd.h b/src/include/pwd.h
new file mode 100644
index 0000000000..a1eb85971a
--- /dev/null
+++ b/src/include/pwd.h
@@ -0,0 +1,76 @@
+#ifndef PG_COMPAT_PWD_H
+#define PG_COMPAT_PWD_H
+
+#if defined(__wasi__)
+
+#include <sys/types.h>
+#include <string.h>
+
+struct passwd {
+	char *pw_name;
+	char *pw_passwd;
+	uid_t pw_uid;
+	uid_t pw_gid;
+	char *pw_gecos;
+	char *pw_dir;
+	char *pw_shell;
+};
+
+static inline int
+getpwuid_r(uid_t uid, struct passwd *pwd, char *buf, size_t buflen,
+		   struct passwd **result)
+{
+	const char *name = "postgres";
+	const char *passwd = "x";
+	const char *gecos = "Static User";
+	const char *dir = "/home/postgres";
+	const char *shell = "/bin/sh";
+	size_t need = strlen(name) + strlen(passwd) + strlen(gecos) +
+		strlen(dir) + strlen(shell) + 5;
+	char *p = buf;
+
+	if (buflen < need)
+	{
+		*result = NULL;
+		return -1;
+	}
+
+#define PG_PWD_COPY(field, value) \
+	do { \
+		size_t len = strlen(value) + 1; \
+		memcpy(p, value, len); \
+		pwd->field = p; \
+		p += len; \
+	} while (0)
+
+	PG_PWD_COPY(pw_name, name);
+	PG_PWD_COPY(pw_passwd, passwd);
+	PG_PWD_COPY(pw_gecos, gecos);
+	PG_PWD_COPY(pw_dir, dir);
+	PG_PWD_COPY(pw_shell, shell);
+
+#undef PG_PWD_COPY
+
+	pwd->pw_uid = uid;
+	pwd->pw_gid = uid;
+	*result = pwd;
+	return 0;
+}
+
+static inline struct passwd *
+getpwuid(uid_t uid)
+{
+	static struct passwd pwd;
+	static char buf[128];
+	struct passwd *result;
+
+	if (getpwuid_r(uid, &pwd, buf, sizeof(buf), &result) != 0)
+		return NULL;
+	return result;
+}
+
+#else
+#include_next <pwd.h>
+#endif
+
+#endif
