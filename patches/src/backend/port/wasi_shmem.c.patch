index 0000000000..0d8f92df3f
--- /dev/null
+++ b/src/backend/port/wasi_shmem.c
@@ -0,0 +1,75 @@
+/*-------------------------------------------------------------------------
+ *
+ * wasi_shmem.c
+ *	  Implement shared memory for the single-process WASI build.
+ *
+ *-------------------------------------------------------------------------
+ */
+#include "postgres.h"
+
+#include <sys/stat.h>
+#include <unistd.h>
+
+#include "miscadmin.h"
+#include "storage/pg_shmem.h"
+#include "utils/guc.h"
+
+unsigned long UsedShmemSegID = 1;
+void	   *UsedShmemSegAddr = NULL;
+
+PGShmemHeader *
+PGSharedMemoryCreate(Size size, PGShmemHeader **shim)
+{
+	PGShmemHeader *hdr;
+	struct stat statbuf;
+
+	hdr = (PGShmemHeader *) calloc(1, size);
+	if (hdr == NULL)
+		ereport(FATAL,
+				(errcode(ERRCODE_OUT_OF_MEMORY),
+				 errmsg("could not allocate shared memory")));
+
+	hdr->magic = PGShmemMagic;
+	hdr->creatorPID = getpid();
+	hdr->totalsize = size;
+	hdr->freeoffset = MAXALIGN(sizeof(PGShmemHeader));
+
+	if (DataDir != NULL && stat(DataDir, &statbuf) == 0)
+	{
+		hdr->device = statbuf.st_dev;
+		hdr->inode = statbuf.st_ino;
+	}
+
+	UsedShmemSegAddr = hdr;
+	*shim = hdr;
+	return hdr;
+}
+
+bool
+PGSharedMemoryIsInUse(unsigned long id1, unsigned long id2)
+{
+	(void) id1;
+	(void) id2;
+	return false;
+}
+
+void
+PGSharedMemoryDetach(void)
+{
+	UsedShmemSegAddr = NULL;
+}
+
+void
+GetHugePageSize(Size *hugepagesize, int *mmap_flags)
+{
+	*hugepagesize = 0;
+	*mmap_flags = 0;
+}
+
+bool
+check_huge_page_size(int *newval, void **extra, GucSource source)
+{
+	(void) extra;
+	(void) source;
+	return *newval == 0;
+}
