+static bool
+pglite_wasi_is_static_library(const char *filename, const char *name)
+{
+	size_t		name_len = strlen(name);
+	size_t		filename_len = strlen(filename);
+	const char *suffix = "";
+	size_t		suffix_len = 0;
+
+	if (filename_len > 3 && strcmp(filename + filename_len - 3, ".so") == 0)
+	{
+		suffix = ".so";
+		suffix_len = 3;
+	}
+
+	if (strcmp(filename, name) == 0)
+		return true;
+	if (filename_len == name_len + suffix_len &&
+		strncmp(filename, name, name_len) == 0 &&
+		strcmp(filename + name_len, suffix) == 0)
+		return true;
+	if (filename_len > name_len + suffix_len &&
+		strncmp(filename + filename_len - name_len - suffix_len, name, name_len) == 0 &&
+		strcmp(filename + filename_len - suffix_len, suffix) == 0 &&
+		(filename[filename_len - name_len - suffix_len - 1] == '/' ||
+		 filename[filename_len - name_len - suffix_len - 1] == '\\'))
+		return true;
+	if (filename_len > name_len + suffix_len + 3 &&
+		strncmp(filename + filename_len - name_len - suffix_len - 3, "lib", 3) == 0 &&
+		strncmp(filename + filename_len - name_len - suffix_len, name, name_len) == 0 &&
+		strcmp(filename + filename_len - suffix_len, suffix) == 0 &&
+		(filename[filename_len - name_len - suffix_len - 4] == '/' ||
+		 filename[filename_len - name_len - suffix_len - 4] == '\\'))
+		return true;
+	return false;
+}
