+static int
+wasi_putbytes(const void *b, size_t len)
+{
+	const char *s = b;
+
+	while (len > 0)
+	{
+		ssize_t written = secure_write(MyProcPort, s, len);
+
+		if (written < 0)
+		{
+			if (errno == EINTR)
+				continue;
+			return EOF;
+		}
+		if (written == 0)
+			return EOF;
+
+		s += written;
+		len -= written;
+	}
+
+	return 0;
+}
+
+static int
+socket_putmessage(char msgtype, const char *s, size_t len)
+{
+	uint32		n32;
+
+	if (PqCommBusy)
+		return 0;
+
+	PqCommBusy = true;
+	if (wasi_putbytes(&msgtype, 1))
+		goto fail;
+
+	n32 = pg_hton32((uint32) (len + 4));
+	if (wasi_putbytes(&n32, 4))
+		goto fail;
+
+	if (wasi_putbytes(s, len))
+		goto fail;
+
+	PqCommBusy = false;
+	return 0;
+
+fail:
+	PqCommBusy = false;
+	return EOF;
+}
+
+static void
+socket_putmessage_noblock(char msgtype, const char *s, size_t len)
+{
+	(void) socket_putmessage(msgtype, s, len);
+}
