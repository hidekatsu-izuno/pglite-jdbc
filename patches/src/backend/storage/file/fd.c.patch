+#endif
 }
 
+#ifdef __wasi__
+void
+pglite_reset_file_access(void)
+{
+	int			i;
+
+	if (SizeVfdCache > 0)
+	{
+		for (i = 1; i < SizeVfdCache; i++)
+		{
+			if (VfdCache[i].fileName != NULL)
+			{
+				if (VfdCache[i].fd != VFD_CLOSED)
+					close(VfdCache[i].fd);
+				free(VfdCache[i].fileName);
+			}
+		}
+
+		free(VfdCache);
+		VfdCache = NULL;
+		SizeVfdCache = 0;
+	}
+
+	nfile = 0;
+#ifdef USE_ASSERT_CHECKING
+	temporary_files_allowed = false;
+#endif
+	numAllocatedDescs = 0;
+}
+#endif
