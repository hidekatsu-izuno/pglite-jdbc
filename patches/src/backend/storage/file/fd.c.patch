 	DO_DB(elog(LOG, "PathNameOpenFilePerm: %s %x %o",
 			   fileName, fileFlags, fileMode));
 
+#ifdef __wasi__
+	/*
+	 * WASI libc has to resolve paths through preopens, and relative-path
+	 * resolution can become fragile across the in-process initdb subprocess
