+#ifdef USE_DSM_WASI
+typedef struct WasiDsmSegment
+{
+	dsm_handle	handle;
+	void	   *address;
+	Size		size;
+	struct WasiDsmSegment *next;
+} WasiDsmSegment;
+
+static WasiDsmSegment *wasi_dsm_segments;
+
+static WasiDsmSegment *
+wasi_find_dsm_segment(dsm_handle handle)
+{
+	WasiDsmSegment *seg;
+
+	for (seg = wasi_dsm_segments; seg != NULL; seg = seg->next)
+	{
+		if (seg->handle == handle)
+			return seg;
+	}
+
+	return NULL;
+}
+
+static bool
+dsm_impl_wasi(dsm_op op, dsm_handle handle, Size request_size,
+			  void **impl_private, void **mapped_address, Size *mapped_size,
+			  int elevel)
+{
+	WasiDsmSegment *seg;
+
+	switch (op)
+	{
+		case DSM_OP_CREATE:
+			if (wasi_find_dsm_segment(handle) != NULL)
+				return false;
+
+			seg = malloc(sizeof(WasiDsmSegment));
+			if (seg == NULL)
+				goto out_of_memory;
+			seg->address = calloc(1, request_size);
+			if (seg->address == NULL)
+			{
+				free(seg);
+				goto out_of_memory;
+			}
+			seg->handle = handle;
+			seg->size = request_size;
+			seg->next = wasi_dsm_segments;
+			wasi_dsm_segments = seg;
+			*impl_private = seg;
+			*mapped_address = seg->address;
+			*mapped_size = seg->size;
+			return true;
+
+		case DSM_OP_ATTACH:
+			seg = wasi_find_dsm_segment(handle);
+			if (seg == NULL)
+				return false;
+			*impl_private = seg;
+			*mapped_address = seg->address;
+			*mapped_size = seg->size;
+			return true;
+
+		case DSM_OP_DETACH:
+			*impl_private = NULL;
+			*mapped_address = NULL;
+			*mapped_size = 0;
+			return true;
+
+		case DSM_OP_DESTROY:
+		{
+			WasiDsmSegment **prev = &wasi_dsm_segments;
+
+			while ((seg = *prev) != NULL)
+			{
+				if (seg->handle == handle)
+				{
+					*prev = seg->next;
+					free(seg->address);
+					free(seg);
+					break;
+				}
+				prev = &seg->next;
+			}
+			*impl_private = NULL;
+			*mapped_address = NULL;
+			*mapped_size = 0;
+			return true;
+		}
+	}
+
+	return false;
+
+out_of_memory:
+	ereport(elevel,
+			(errcode(ERRCODE_OUT_OF_MEMORY),
+			 errmsg("could not allocate dynamic shared memory segment")));
+	return false;
+}
+#endif
