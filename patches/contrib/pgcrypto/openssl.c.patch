diff --git a/contrib/pgcrypto/openssl.c b/contrib/pgcrypto/openssl.c
index f179e80c84..e10e4bca74 100644
--- a/contrib/pgcrypto/openssl.c
+++ b/contrib/pgcrypto/openssl.c
@@ -29,6 +29,349 @@
  * contrib/pgcrypto/openssl.c
  */
 
+#ifdef __wasi__
+#include "postgres.h"
+
+#include "common/cryptohash.h"
+#include "common/md5.h"
+#include "common/sha1.h"
+#include "common/sha2.h"
+#include "px.h"
+
+#define PGLITE_CRYPTO_AES 1
+#define PGLITE_CRYPTO_MODE_ECB 1
+#define PGLITE_CRYPTO_MODE_CBC 2
+#define PGLITE_CRYPTO_MODE_CFB 3
+#define MAX_KEY		(512/8)
+#define MAX_IV		(128/8)
+
+extern int pglite_crypto_cipher(int algorithm, int mode, int encrypt,
+								int padding, const uint8 *key,
+								int key_len, const uint8 *iv, int iv_len,
+								const uint8 *data, int data_len,
+								uint8 *result, int result_len)
+__attribute__((import_module("env"), import_name("pglite_crypto_cipher")));
+
+typedef struct
+{
+	pg_cryptohash_ctx *ctx;
+	unsigned	result_size;
+	unsigned	block_size;
+} PGliteWasiDigest;
+
+typedef struct
+{
+	int			algorithm;
+	int			mode;
+	unsigned	key_size;
+	unsigned	iv_size;
+	uint8		key[MAX_KEY];
+	uint8		iv[MAX_IV];
+	unsigned	key_len;
+} PGliteWasiCipher;
+
+static unsigned
+digest_result_size(PX_MD *h)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	return digest->result_size;
+}
+
+static unsigned
+digest_block_size(PX_MD *h)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	return digest->block_size;
+}
+
+static void
+digest_reset(PX_MD *h)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	if (pg_cryptohash_init(digest->ctx) < 0)
+		elog(ERROR, "%s", pg_cryptohash_error(digest->ctx));
+}
+
+static void
+digest_update(PX_MD *h, const uint8 *data, unsigned dlen)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	if (pg_cryptohash_update(digest->ctx, data, dlen) < 0)
+		elog(ERROR, "%s", pg_cryptohash_error(digest->ctx));
+}
+
+static void
+digest_finish(PX_MD *h, uint8 *dst)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	if (pg_cryptohash_final(digest->ctx, dst, digest->result_size) < 0)
+		elog(ERROR, "%s", pg_cryptohash_error(digest->ctx));
+}
+
+static void
+digest_free(PX_MD *h)
+{
+	PGliteWasiDigest *digest = (PGliteWasiDigest *) h->p.ptr;
+
+	pg_cryptohash_free(digest->ctx);
+	pfree(digest);
+	pfree(h);
+}
+
+static unsigned
+cipher_block_size(PX_Cipher *c)
+{
+	return 16;
+}
+
+static unsigned
+cipher_key_size(PX_Cipher *c)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+
+	return cipher->key_size;
+}
+
+static unsigned
+cipher_iv_size(PX_Cipher *c)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+
+	return cipher->iv_size;
+}
+
+static int
+cipher_init(PX_Cipher *c, const uint8 *key, unsigned klen, const uint8 *iv)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+	unsigned	key_len;
+
+	if (klen <= 128 / 8)
+		key_len = 128 / 8;
+	else if (klen <= 192 / 8)
+		key_len = 192 / 8;
+	else if (klen <= 256 / 8)
+		key_len = 256 / 8;
+	else
+		return PXE_KEY_TOO_BIG;
+	if (key_len > cipher->key_size)
+		key_len = cipher->key_size;
+	memset(cipher->key, 0, sizeof(cipher->key));
+	memcpy(cipher->key, key, klen);
+	cipher->key_len = key_len;
+	memset(cipher->iv, 0, sizeof(cipher->iv));
+	if (iv != NULL && cipher->iv_size > 0)
+		memcpy(cipher->iv, iv, cipher->iv_size);
+	return PXE_OK;
+}
+
+static int
+cipher_encrypt(PX_Cipher *c, int padding, const uint8 *data, unsigned dlen,
+			   uint8 *res, unsigned *rlen)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+	int			len;
+
+	len = pglite_crypto_cipher(cipher->algorithm, cipher->mode, 1,
+							   padding, cipher->key, cipher->key_len,
+							   cipher->iv, cipher->iv_size, data, dlen,
+							   res, dlen + 32);
+	if (len < 0)
+		return PXE_ENCRYPT_FAILED;
+	*rlen = len;
+	return PXE_OK;
+}
+
+static int
+cipher_decrypt(PX_Cipher *c, int padding, const uint8 *data, unsigned dlen,
+			   uint8 *res, unsigned *rlen)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+	int			len;
+
+	len = pglite_crypto_cipher(cipher->algorithm, cipher->mode, 0,
+							   padding, cipher->key, cipher->key_len,
+							   cipher->iv, cipher->iv_size, data, dlen,
+							   res, dlen + 32);
+	if (len < 0)
+		return PXE_DECRYPT_FAILED;
+	*rlen = len;
+	return PXE_OK;
+}
+
+static void
+cipher_free(PX_Cipher *c)
+{
+	PGliteWasiCipher *cipher = (PGliteWasiCipher *) c->ptr;
+
+	px_memset(cipher, 0, sizeof(*cipher));
+	pfree(cipher);
+	pfree(c);
+}
+
+static bool
+digest_type_for_name(const char *name, pg_cryptohash_type *type,
+					 unsigned *result_size, unsigned *block_size)
+{
+	if (pg_strcasecmp(name, "md5") == 0)
+	{
+		*type = PG_MD5;
+		*result_size = MD5_DIGEST_LENGTH;
+		*block_size = 64;
+		return true;
+	}
+	if (pg_strcasecmp(name, "sha1") == 0)
+	{
+		*type = PG_SHA1;
+		*result_size = SHA1_DIGEST_LENGTH;
+		*block_size = 64;
+		return true;
+	}
+	if (pg_strcasecmp(name, "sha224") == 0)
+	{
+		*type = PG_SHA224;
+		*result_size = PG_SHA224_DIGEST_LENGTH;
+		*block_size = PG_SHA224_BLOCK_LENGTH;
+		return true;
+	}
+	if (pg_strcasecmp(name, "sha256") == 0)
+	{
+		*type = PG_SHA256;
+		*result_size = PG_SHA256_DIGEST_LENGTH;
+		*block_size = PG_SHA256_BLOCK_LENGTH;
+		return true;
+	}
+	if (pg_strcasecmp(name, "sha384") == 0)
+	{
+		*type = PG_SHA384;
+		*result_size = PG_SHA384_DIGEST_LENGTH;
+		*block_size = PG_SHA384_BLOCK_LENGTH;
+		return true;
+	}
+	if (pg_strcasecmp(name, "sha512") == 0)
+	{
+		*type = PG_SHA512;
+		*result_size = PG_SHA512_DIGEST_LENGTH;
+		*block_size = PG_SHA512_BLOCK_LENGTH;
+		return true;
+	}
+	return false;
+}
+
+int
+px_find_digest(const char *name, PX_MD **res)
+{
+	PGliteWasiDigest *digest;
+	PX_MD	   *h;
+	pg_cryptohash_type type;
+	unsigned	result_size;
+	unsigned	block_size;
+
+	CheckBuiltinCryptoMode();
+
+	if (!digest_type_for_name(name, &type, &result_size, &block_size))
+		return PXE_NO_HASH;
+
+	digest = palloc0(sizeof(*digest));
+	digest->result_size = result_size;
+	digest->block_size = block_size;
+	digest->ctx = pg_cryptohash_create(type);
+	if (digest->ctx == NULL)
+	{
+		pfree(digest);
+		return PXE_NO_HASH;
+	}
+	if (pg_cryptohash_init(digest->ctx) < 0)
+	{
+		pg_cryptohash_free(digest->ctx);
+		pfree(digest);
+		return PXE_NO_HASH;
+	}
+
+	h = palloc0(sizeof(*h));
+	h->result_size = digest_result_size;
+	h->block_size = digest_block_size;
+	h->reset = digest_reset;
+	h->update = digest_update;
+	h->finish = digest_finish;
+	h->free = digest_free;
+	h->p.ptr = digest;
+
+	*res = h;
+	return PXE_OK;
+}
+
+int
+px_find_cipher(const char *name, PX_Cipher **res)
+{
+	PGliteWasiCipher *cipher;
+	PX_Cipher  *c;
+	int			mode;
+
+	name = px_resolve_alias((PX_Alias[]) {
+		{"aes", "aes-cbc"},
+		{"rijndael", "aes-cbc"},
+		{"rijndael-cbc", "aes-cbc"},
+		{"rijndael-ecb", "aes-ecb"},
+		{"rijndael-cfb", "aes-cfb"},
+		{NULL, NULL}
+	}, name);
+
+	if (pg_strcasecmp(name, "aes-cbc") == 0)
+		mode = PGLITE_CRYPTO_MODE_CBC;
+	else if (pg_strcasecmp(name, "aes-ecb") == 0)
+		mode = PGLITE_CRYPTO_MODE_ECB;
+	else if (pg_strcasecmp(name, "aes-cfb") == 0)
+		mode = PGLITE_CRYPTO_MODE_CFB;
+	else
+		return PXE_NO_CIPHER;
+
+	cipher = palloc0(sizeof(*cipher));
+	cipher->algorithm = PGLITE_CRYPTO_AES;
+	cipher->mode = mode;
+	cipher->key_size = 32;
+	cipher->iv_size = mode == PGLITE_CRYPTO_MODE_ECB ? 0 : 16;
+
+	c = palloc0(sizeof(*c));
+	c->ptr = cipher;
+	c->block_size = cipher_block_size;
+	c->key_size = cipher_key_size;
+	c->iv_size = cipher_iv_size;
+	c->init = cipher_init;
+	c->encrypt = cipher_encrypt;
+	c->decrypt = cipher_decrypt;
+	c->free = cipher_free;
+
+	*res = c;
+	return PXE_OK;
+}
+
+bool
+CheckFIPSMode(void)
+{
+	return false;
+}
+
+void
+CheckBuiltinCryptoMode(void)
+{
+	if (builtin_crypto_enabled == BC_ON)
+		return;
+
+	if (builtin_crypto_enabled == BC_OFF)
+		ereport(ERROR,
+				errmsg("use of built-in crypto functions is disabled"));
+
+	Assert(builtin_crypto_enabled == BC_FIPS);
+}
+
+#else
+
 #include "postgres.h"
 
 #include <openssl/crypto.h>
@@ -886,3 +1229,4 @@ CheckBuiltinCryptoMode(void)
 		ereport(ERROR,
 				errmsg("use of non-FIPS validated crypto not allowed when OpenSSL is in FIPS mode"));
 }
+#endif
