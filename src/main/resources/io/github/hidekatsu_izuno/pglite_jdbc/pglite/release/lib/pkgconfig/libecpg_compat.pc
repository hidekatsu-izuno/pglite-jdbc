prefix=/pglite
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libecpg_compat
Description: PostgreSQL libecpg_compat library
URL: https://www.postgresql.org/
Version: 18.3
Requires: 
Requires.private: libecpg, libpgtypes
Cflags: -I${includedir}
Libs: -L${libdir} -lecpg_compat
Libs.private: -L/home/hidek/git/pglite-custom/.bin/pglite-wasi/libs/lib -lecpg -lpgcommon -lpgport -lpq -lm
